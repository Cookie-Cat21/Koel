# Seylan Bank Gateway
SEYLAN_GATEWAY_DEFAULT=https://dev.apigateway1.seylan.lk:2260
SEYLAN_GATEWAY_QR=https://dev.apigateway1.seylan.lk:2250
SEYLAN_API_KEY=
SEYLAN_CHECKSUM_KEY_MERCHANT=
SEYLAN_CHECKSUM_KEY_LANKAQR=
SEYLAN_JUSTPAY_CODE=

# Merchant QR (bank-provisioned)
SEYLAN_MERCHANT_INSTITUTION_ID=1
SEYLAN_MERCHANT_CHANNEL_USER_ID=
SEYLAN_MERCHANT_CHANNEL_PASS=
SEYLAN_MERCHANT_LOGIN_ID=
SEYLAN_MERCHANT_LOGIN_PASS=
SEYLAN_MERCHANT_MID=
SEYLAN_MERCHANT_TID=

# Feature flags (set to true once credentials are confirmed)
USE_SEYLAN_REAL=false
SEYLAN_ENABLE_TRANSFERS=false
SEYLAN_ENABLE_MERCHANT_QR=false

# MPGS (Mastercard Payment Gateway Services) — Hosted Checkout v79
MPGS_HOST=test-seylan.mtf.gateway.mastercard.com
MPGS_MERCHANT_ID=
MPGS_API_PASSWORD=
# Optional; omit for merchant.{MERCHANT_ID} + Integration Password auth (typical for Hosted Checkout).
MPGS_OPERATOR_ID=
MPGS_API_VERSION=79
MPGS_ENABLE=false

# PayHere — Hosted Checkout (sandbox)
PAYHERE_MERCHANT_ID=
PAYHERE_SECRET=
# Optional override; defaults to BACKEND_BASE_URL/api/payhere/notify
# PAYHERE_NOTIFY_URL=

# AI
GROQ_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# Telegram bot (optional — disabled when unset)
TELEGRAM_BOT_TOKEN=

# Database (Neon PostgreSQL)
DATABASE_URL=

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Demo auth & admin (override in production — code ships a demo default secret)
DEMO_SESSION_SECRET=
DEMO_ADMIN_KEY=
# DEMO_AUTH_REQUIRED=true
# MPGS_WEBHOOK_VERIFY=true
# PAYHERE_STRICT_NOTIFY_HASH=true

# App
CORS_ORIGINS=http://localhost:3000,http://localhost:3003,http://localhost:3005,https://frontend-taupe-three-96.vercel.app,https://ceyfi.app
FRONTEND_BASE_URL=https://frontend-taupe-three-96.vercel.app
BACKEND_BASE_URL=http://localhost:8000

# Telegram bot (optional — bot disabled when TELEGRAM_BOT_TOKEN is unset)
TELEGRAM_BOT_TOKEN=
INTERNAL_API_BASE=http://localhost:8000

# Optional — proxy CSE watch/alerts from Chime (Market module)
CHIME_API_BASE=
CHIME_DEMO_TELEGRAM_ID=123456789
