# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Postgres connection string (Supabase, Neon, or local compose)
# Local: docker compose up -d → postgresql://chime:chime@localhost:5432/chime
# Shared by bot, poller, and dashboard (web/).
# Quote the value if it contains & (e.g. Neon sslmode / channel_binding) —
# unquoted `source .env` in bash truncates at & and can hit the wrong DB.
DATABASE_URL="postgresql://chime:chime@localhost:5432/chime"

# CSE API (no trailing slash required)
CSE_BASE_URL=https://www.cse.lk/api
# Soft min gap (seconds) between CSE HTTP calls on a shared CSEClient
# (bot + poller). Default 0 = off; raise (e.g. 0.2) if cse.lk rate-limits.
# Settings.cse_min_interval_seconds. Distinct from PDF_ENRICH_SLEEP_SECONDS.
CSE_MIN_INTERVAL_SECONDS=0

# Poller
POLL_INTERVAL_SECONDS=15
# Near-realtime dash default is 15s during market hours (floor 5). Dash
# PriceRefresh soft-reloads from Postgres ~15s — freshness cannot beat this.
POLL_JITTER_SECONDS=5
# CSE HTTP client timeout (seconds). Settings.http_timeout_seconds.
HTTP_TIMEOUT_SECONDS=15

# Optional: delete price_snapshots older than N days for symbols NOT on any
# watchlist (after each successful market persist). Default 0 = off.
# Watched symbols keep full history forever. Fail-soft on cleanup errors.
# Settings.snapshot_retention_days (chime/config.py).
SNAPSHOT_RETENTION_DAYS=0

# Logging
LOG_LEVEL=INFO

# Health HTTP server (bot / poller / both)
HEALTH_HOST=127.0.0.1
HEALTH_PORT=8080

# CSE client circuit breaker
CIRCUIT_FAIL_MAX=5
CIRCUIT_RESET_SECONDS=60

# Market hours gate (poller). Settings.market_tz / market_open / market_close.
# Colombo has no DST — keep Asia/Colombo unless you intentionally shift the window.
MARKET_TZ=Asia/Colombo
MARKET_OPEN=09:30
MARKET_CLOSE=14:30

# Per-user Telegram command rate limit (in-memory sliding window)
BOT_CMD_RATE_PER_MINUTE=20

# Optional bulk disclosure discovery (POST /approvedAnnouncement + stocks name map).
# Default 0 = per-symbol getAnnouncementByCompany only. Set 1 to reduce HTTP for
# large disclosure watchlists; fails soft to per-symbol on bulk/map errors.
# Settings.disclosure_bulk_feed (chime/config.py). Not DISCLOSURE_BULK.
DISCLOSURE_BULK_FEED=0

# Optional CSE sector index ingest (POST /allSectors → sectors table).
# Default 0 = skip. Set 1 to persist sector board each poll tick (fail-soft).
# Thin GET /api/v1/sectors reads Postgres only. Settings.sectors_ingest.
SECTORS_INGEST=0

# Polite pause (seconds) before each symbol's legacy POST /announcements PDF
# enrich call (filePath → pdf_url). Outside poll advisory lock. Set 0 to skip
# sleep; raise if CSE rate-limits. Settings.pdf_enrich_sleep_seconds.
PDF_ENRICH_SLEEP_SECONDS=0.5

# ---------------------------------------------------------------------------
# Financial PDF metrics + YoY compare (default OFF — research-hardened extract)
# ---------------------------------------------------------------------------
# Extract Basic EPS / revenue / PAT from financial PDFs after pdf_url enrich.
FINANCIAL_METRICS_ENABLED=0
# Pair each extractable filing with prior-year comparable and store deltas.
FILING_COMPARE_ENABLED=0
# Absolute /alert SYMBOL eps above|below X → Telegram (requires metrics).
EPS_CALC_ALERTS_ENABLED=0
# YoY % alerts: /alert SYMBOL eps|rev|profit yoy above|below PCT
YOY_COMPARE_ALERTS_ENABLED=0
# When 1, evaluate eps/yoy rules into alert_log as [shadow] without Telegram
# unless the matching *_ALERTS_ENABLED flag is also 1.
METRICS_SHADOW_MODE=1
# Append YoY block onto disclosure Telegram messages when comparison exists.
YOY_APPEND_TO_DISCLOSURE=0

# ---------------------------------------------------------------------------
# Dashboard (web/) — complete env checklist (E6-O01)
# Copy these into web/.env.local for Next.js (see also web/.env.example).
# Auth model: docs/adr/001-dash-auth.md
# Ops deploy: docs/runbooks/PRODUCTION.md
# ---------------------------------------------------------------------------

# Demo auth opt-in (ADR 001). Exact value "1" enables POST /api/v1/auth/demo.
# Production / public URL: leave unset or 0 — never enable on an open network.
# Optional https origin for Telegram alert deep links to the dash symbol page.
# Example: DASH_PUBLIC_URL=https://chime.example.com
# Must be https; no path/query/userinfo. Empty = omit link from Telegram cards.
DASH_PUBLIC_URL=

DASH_DEMO_AUTH=0

# Comma-separated Telegram IDs allowed for demo sign-in (required when demo on).
# Must match users.telegram_id rows you intend to manage.
# Example (local only): DASH_DEMO_TELEGRAM_IDS=123456789
DASH_DEMO_TELEGRAM_IDS=

# Optional: render demo allowlist as a <select> on /login (default off — S-11).
# Local / Cloud Agent only. Never enable on public Vercel.
# DASH_DEMO_SHOW_ALLOWLIST=1

# Optional single default pre-filled on /login UI (must also be in allowlist).
# DASH_DEFAULT_TELEGRAM_ID=123456789

# Required non-empty signing key for HttpOnly chime_session cookie.
# Fail-closed if empty: session/mutate routes return 503 degraded.
# Generate e.g.: openssl rand -hex 32
DASH_SESSION_SECRET=

# Ops telegram IDs allowed to see full GET /api/v1/health detail (S-05).
# Empty = summary only for every logged-in user (fail closed for detail).
# Example: DASH_OPS_TELEGRAM_IDS=123456789
DASH_OPS_TELEGRAM_IDS=

# Optional: poller health URL for GET /api/v1/health proxy (omit → DB-only).
# Loopback HTTP only — non-loopback is rejected by the dash (SSRF).
# HEALTH_URL=http://127.0.0.1:8080/health

# Optional SSR → /api/v1 origin (cookie-bearing). Loopback only; default
# http://127.0.0.1:$PORT. Never derived from client Host.
# DASH_INTERNAL_ORIGIN=http://127.0.0.1:3000

# Telegram Login Widget. Disabled unless exact value 1 and TELEGRAM_BOT_TOKEN
# is set; verifies Telegram HMAC before minting dashboard sessions.
DASH_TELEGRAM_LOGIN=0

# Mutating APIs (POST/DELETE watchlist|alerts, POST logout) require:
#   1) signed chime_session cookie (from demo/Telegram login)
#   2) matching X-CSRF-Token header (csrf cookie / csrf_token from login)
# curl smoke: scripts/factory/dash_smoke.sh (login + health; mutate gate without session)

# ---------------------------------------------------------------------------
# AI filing briefs (BriefSettings in chime/briefs/__init__.py; default OFF)
# briefs_enabled() requires AI_BRIEFS_ENABLED=1 AND a non-empty AI_API_KEY.
# See docs/runbooks/TIJORI.md and docs/factory/TIJORI_CSE_PLAN.md
# ---------------------------------------------------------------------------
AI_BRIEFS_ENABLED=0
AI_PROVIDER=gemini
# AI_PROVIDER=groq
# AI_PROVIDER=openrouter
AI_API_KEY=
# Soft-defaults when unset: gemini-2.0-flash | groq llama-3.3-70b-versatile |
# openrouter openai/gpt-4o-mini (so AI_PROVIDER alone does not burn the daily cap).
AI_MODEL=gemini-2.0-flash
# AI_MODEL=llama-3.3-70b-versatile
# AI_MODEL=openai/gpt-4o-mini
# Optional failover chain (comma-separated; same length preferred).
# On HTTP 429 / 5xx / timeout the worker tries the next keyed slot.
# Empty key skips that slot. Missing model → provider soft-default.
# AI_BACKUP_PROVIDERS=groq,openrouter
# AI_BACKUP_API_KEYS=
# AI_BACKUP_MODELS=llama-3.3-70b-versatile,openai/gpt-4o-mini
AI_MAX_BRIEFS_PER_DAY=50
AI_MAX_INPUT_CHARS=12000
# Provider HTTP timeout (seconds). BriefSettings.http_timeout_seconds.
AI_HTTP_TIMEOUT_SECONDS=30
# Pause between LLM calls while draining pending briefs (0 = no pacing).
# BriefSettings.sleep_seconds.
AI_BRIEF_SLEEP_SECONDS=0.5
# Max PDF download size for brief extract. BriefSettings.pdf_max_bytes.
PDF_MAX_BYTES=5242880
# Wait for legacy pdf_url enrich before title-only summarize (0 = claim now).
# Keyed off brief updated_at; promote restarts the window.
# BriefSettings.pdf_grace_seconds.
BRIEF_PDF_GRACE_SECONDS=120
# After a transient CDN miss requeue, wait before reclaim (0 = immediate).
# Prevents CDN hammer / queue starvation. BriefSettings.cdn_backoff_seconds.
BRIEF_CDN_BACKOFF_SECONDS=300
# When AI is enabled, re-queue recent skipped ledger rows as pending (0 = off).
# BriefSettings.skipped_promote_hours.
BRIEF_SKIPPED_PROMOTE_HOURS=24

# ---------------------------------------------------------------------------
# AI scenario stub (ScenarioSettings in chime/scenarios; default OFF)
# Phase 3 fence only — no LLM wiring yet. Guardrails reject buy/sell language.
# Dash /scenarios reads the same AI_SCENARIOS_ENABLED flag (coming soon unless 1).
# See docs/factory/TIJORI_CSE_PLAN.md (Phase 3 — Optional scenario AI)
# ---------------------------------------------------------------------------
AI_SCENARIOS_ENABLED=0
