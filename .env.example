# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Postgres connection string (Supabase, Neon, or local compose)
# Local: docker compose up -d → postgresql://chime:chime@localhost:5432/chime
# Shared by bot, poller, and dashboard (web/).
DATABASE_URL=postgresql://chime:chime@localhost:5432/chime

# CSE API (no trailing slash required)
CSE_BASE_URL=https://www.cse.lk/api

# Poller
POLL_INTERVAL_SECONDS=60
POLL_JITTER_SECONDS=5

# Logging
LOG_LEVEL=INFO

# Health HTTP server (bot / poller / both)
HEALTH_HOST=127.0.0.1
HEALTH_PORT=8080

# CSE client circuit breaker
CIRCUIT_FAIL_MAX=5
CIRCUIT_RESET_SECONDS=60

# Per-user Telegram command rate limit (in-memory sliding window)
BOT_CMD_RATE_PER_MINUTE=20

# ---------------------------------------------------------------------------
# Dashboard (web/) — also copy to web/.env.local for Next.js
# See docs/adr/001-dash-auth.md and docs/runbooks/PRODUCTION.md
# ---------------------------------------------------------------------------

# Demo auth opt-in (ADR 001). Refuse demo login unless exactly 1.
# Production / public URL: leave unset or 0 — never enable on an open network.
DASH_DEMO_AUTH=0

# Comma-separated Telegram IDs allowed for demo sign-in (required when demo on).
# Must match users.telegram_id rows you intend to manage.
DASH_DEMO_TELEGRAM_IDS=

# Optional single default for /login UI (must also be in the allowlist above)
# DASH_DEFAULT_TELEGRAM_ID=

# Required non-empty signing key for HttpOnly chime_session cookie (fail-closed if empty)
DASH_SESSION_SECRET=

# Optional: poller health URL for GET /api/v1/health proxy (omit → DB-only)
# HEALTH_URL=http://127.0.0.1:8080/health

# Future (disabled stub — do not set in v1)
# DASH_TELEGRAM_LOGIN=0
