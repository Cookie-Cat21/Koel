# Chime dashboard (Next.js) — local / demo

# Postgres (same DB as bot/poller). No cse.lk from web/.
DATABASE_URL=postgresql://chime:chime@localhost:5432/chime

# Demo auth (ADR 001) — refuse unless DASH_DEMO_AUTH=1
DASH_DEMO_AUTH=1
DASH_DEMO_TELEGRAM_IDS=123456789
# Optional single default for /login when also allowlisted
DASH_DEFAULT_TELEGRAM_ID=123456789

# Required non-empty signing key for HttpOnly session cookie
DASH_SESSION_SECRET=dev-only-change-me-to-a-long-random-string

# Optional poller health proxy for GET /api/v1/health (omit → DB-only)
# HEALTH_URL=http://127.0.0.1:8080/health

# Future (disabled stub — do not set in v1)
# DASH_TELEGRAM_LOGIN=0
