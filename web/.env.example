# Chime dashboard (Next.js) — local / demo
# Root .env.example lists the same DASH_* keys for the secret checklist.
# Production: see docs/runbooks/PRODUCTION.md (DASH_DEMO_AUTH=0 on public URLs).
#
# Poller / briefs only (do NOT copy into web/): DISCLOSURE_BULK_FEED,
# PDF_ENRICH_SLEEP_SECONDS, SECTORS_INGEST, SNAPSHOT_RETENTION_DAYS,
# AI_BRIEFS_ENABLED, AI_PROVIDER, AI_API_KEY, AI_MODEL, AI_MAX_BRIEFS_PER_DAY,
# AI_MAX_INPUT_CHARS, AI_HTTP_TIMEOUT_SECONDS, AI_BRIEF_SLEEP_SECONDS,
# PDF_MAX_BYTES, BRIEF_PDF_GRACE_SECONDS, BRIEF_CDN_BACKOFF_SECONDS,
# BRIEF_SKIPPED_PROMOTE_HOURS — see root .env.example and docs/runbooks/TIJORI.md.

# Postgres (same DB as bot/poller). No cse.lk from web/.
# Production / Vercel: use the Neon **direct** endpoint (not -pooler) so SSR
# sees stocks + disclosures + filing_metrics. Example:
# DATABASE_URL=postgresql://neondb_owner:***@ep-….aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://chime:chime@localhost:5432/chime

# Demo auth (ADR 001) — refuse unless DASH_DEMO_AUTH=1
# Public Vercel: DASH_DEMO_AUTH=0 (see docs/runbooks/SECURITY_ROTATION.md).
DASH_DEMO_AUTH=1
DASH_DEMO_TELEGRAM_IDS=123456789
# Optional: show allowlist <select> on /login (default off — S-11).
# DASH_DEMO_SHOW_ALLOWLIST=1
# Optional single default for /login when also allowlisted
DASH_DEFAULT_TELEGRAM_ID=123456789

# Required non-empty signing key for HttpOnly session cookie
DASH_SESSION_SECRET=dev-only-change-me-to-a-long-random-string

# Ops telegram IDs for full GET /api/v1/health detail (S-05): poller proxy,
# Telegram delivery, retention, ML. Empty = product health only (DB freshness,
# data inventory, GitHub Actions). Example: DASH_OPS_TELEGRAM_IDS=6370595527
# DASH_OPS_TELEGRAM_IDS=123456789

# Optional SSR → /api/v1 origin (cookie-bearing). Loopback only; default
# http://127.0.0.1:$PORT (or :3000). Never derived from client Host.
# DASH_INTERNAL_ORIGIN=http://127.0.0.1:3000
#
# If Vercel Deployment Protection (SSO) is on, set the automation bypass so
# remaining SSR self-fetches (snapshots/forecast/etc.) are not HTML login pages:
# DASH_VERCEL_PROTECTION_BYPASS=…   # or Vercel’s VERCEL_AUTOMATION_BYPASS_SECRET

# Optional poller health proxy for GET /api/v1/health (omit → DB freshness only).
# Loopback HTTP only (127.0.0.1 / localhost / ::1) — non-loopback is rejected (SSRF).
# On Vercel this cannot reach a remote poller; leave unset and use snapshot age.
# HEALTH_URL=http://127.0.0.1:8080/health
# Optional proxy abort budget in ms (default 3000; non-positive/invalid → default)
# HEALTH_PROXY_TIMEOUT_MS=3000

# GitHub Actions strip on /health (public API; fail-soft). Set to 0 to disable.
# HEALTH_GITHUB_ACTIONS=1
# HEALTH_GITHUB_REPO=ArdenoStudio/Koel
# Optional token for higher rate limits (otherwise unauthenticated 60/hr):
# GITHUB_TOKEN=

# Phase 3 scenario dash stub (default OFF). Same key as poller/bot
# ScenarioSettings — page shows “coming soon” unless AI_SCENARIOS_ENABLED=1.
# Even when 1, no LLM wiring yet (thin stub only).
AI_SCENARIOS_ENABLED=0

# Public marketing CTA — https://t.me/<bot> or https://telegram.me/<bot> only.
# When unset, landing/pricing Telegram buttons fall back to /login.
# NEXT_PUBLIC_TELEGRAM_BOT_URL=

# Telegram Login Widget. Disabled unless exact value 1 and TELEGRAM_BOT_TOKEN
# is set; verifies Telegram HMAC before minting dashboard sessions.
DASH_TELEGRAM_LOGIN=0
# Required only when DASH_TELEGRAM_LOGIN=1.
# TELEGRAM_BOT_TOKEN=
